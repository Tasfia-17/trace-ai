# ─── Primary provider: OpenAI ─────────────────────────────────────────────────
# Recommended for best reasoning quality.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Speed provider: Cerebras ─────────────────────────────────────────────────
# Lowest latency. Select "Cerebras (fast)" in the UI for speed comparison.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gemma-4-31b
# Optional. Leave unset for standard Cerebras Cloud.
# CEREBRAS_BASE_URL=https://api.cerebras.ai

# ─── Privacy provider: Venice.ai TEE ──────────────────────────────────────────
# Privacy-preserving encrypted inference for screenshot/visual evidence.
# The Vision Agent is automatically routed here when this key is set.
# https://venice.ai — create an API key in your Venice dashboard.
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

# ─── Alternate full-workflow provider: Gemini ─────────────────────────────────
# Optional alternate provider. Select "Gemini Flash" in the UI.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
# Optional. Leave unset for the standard Google Gemini API.
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ─── GitHub handoff ───────────────────────────────────────────────────────────
# Required for Trace to open GitHub issues and pull requests.
GITHUB_TOKEN=

# ─── Optional live GPU baseline (speed comparison endpoint) ──────────────────
# If unset, the endpoint fails instead of fabricating comparison data.
# GPU_BASELINE_API_KEY=
# GPU_BASELINE_BASE_URL=https://api.example.com/v1
# GPU_BASELINE_MODEL=
# GPU_BASELINE_PROVIDER_NAME=GPU provider
